# ═══════════════════════════════════════════════════════════════════════════
# SURVEYEASE ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════

# ── DATABASE ────────────────────────────────────────────────────────────────
# Get this from Supabase Dashboard → Project Settings → Database → Connection String
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ── SUPABASE ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── RAPIDOREACH SURVEY PROVIDER ─────────────────────────────────────────────
RAPIDOREACH_APP_ID=your_app_id
RAPIDOREACH_APP_KEY=your_app_key
RAPIDOREACH_APP_SECRET=your_app_secret

# ── SECURITY ────────────────────────────────────────────────────────────────
# Used for webhook HMAC validation (use same as RAPIDOREACH_APP_SECRET)
SURVEY_SECRET_KEY=your_app_secret

# Used for JWT token signing (generate a random 32+ char string)
JWT_SECRET=generate-a-strong-random-string-here-minimum-32-chars

# ── APP ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://surveyease.vercel.app
